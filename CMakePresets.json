{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 4,
        "minor": 3,
        "patch": 3
    },
    "configurePresets": [
        {
            "name": "base-gcc-16.1",
            "hidden": true,
            "description": "A preset with Ninja and GCC 16.1",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "gcc-16.1",
                "CMAKE_CXX_COMPILER": "g++-16.1"
            }
        },
        {
            "name": "debug-gcc-16.1",
            "displayName": "Debug (GCC 16.1 & Ninja)",
            "inherits": "base-gcc-16.1",
            "description": "A debug preset with Ninja and GCC 16.1",
            "binaryDir": "${sourceDir}/build/debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "release-gcc-16.1",
            "displayName": "Release (GCC 16.1 & Ninja)",
            "inherits": "base-gcc-16.1",
            "description": "A release preset with Ninja and GCC 16.1",
            "binaryDir": "${sourceDir}/build/release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "build-debug",
            "displayName": "Build Debug",
            "configurePreset": "debug-gcc-16.1"
        },
        {
            "name": "build-release",
            "displayName": "Build Release",
            "configurePreset": "release-gcc-16.1"
        }
    ]
}